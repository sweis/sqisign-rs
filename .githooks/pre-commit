#!/bin/sh
# Pre-commit hook: enforce rustfmt and clippy.
# Install with: git config core.hooksPath .githooks
set -e

echo "pre-commit: cargo fmt --check"
cargo fmt --check

echo "pre-commit: cargo clippy (correctness/suspicious as deny)"
cargo clippy --no-default-features --features lvl1 --quiet -- \
    -D clippy::correctness -D clippy::suspicious -D warnings 2>&1

echo "pre-commit: OK"
